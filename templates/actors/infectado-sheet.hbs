<form class="{{cssClass}} flexcol" autocomplete="off">
    <!-- HEADER DA FICHA -->
    <header class="sheet-header">
        <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
        <div class="header-fields">
            <div class="charname-box">
                <input name="name" class="charname-input" type="text" value="{{actor.name}}" placeholder="Nome do Personagem"/>
            </div>
            <div class="grid-2col">
                <div class="form-group">
                    <label>Ocupação</label>
                    <input type="text" name="system.ocupacao" value="{{system.ocupacao}}" />
                </div>
                <div class="form-group">
                    <label>Geração</label>
                    <select name="system.geracao">
                        {{selectOptions geracaoOptions selected=system.geracao}}
                    </select>
                </div>
                <div class="form-group span-2">
                    <label>Evento Marcante (Origem)</label>
                    <input type="text" name="system.eventoMarcante" value="{{system.eventoMarcante}}" />
                </div>
            </div>
            
        </div>
    </header>

    <!-- NAVEGAÇÃO / ABAS -->
    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-tab="frente">Frente (Aptidões/Saúde)</a>
        <a class="item" data-tab="verso">Verso (Características/Inventário)</a>
    </nav>

    <!-- CONTEÚDO PRINCIPAL -->
    <section class="sheet-body">
        
        <!-- ABA: FRENTE -->
        <div class="tab frente" data-group="primary" data-tab="frente">
            <div class="grid-2col content-grid">
                <!-- COLUNA ESQUERDA: APTIDÕES -->
                <div class="col-aptidoes">
                    <div style="display:flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid #ddd; margin-bottom: 15px; padding-bottom: 5px;">
                        <h2 class="section-title" style="border: none; margin: 0; padding: 0;">Aptidões</h2>
                        <label style="font-size: 11px; cursor: pointer; color: var(--assimilacao-red); font-weight: bold;" title="Agir por Instinto e rolar D12s">
                            <input type="checkbox" name="flags.assimilacao.rolagemAssimilada" {{checked flags.assimilacao.rolagemAssimilada}}> Ação Instintiva (D12)
                        </label>
                    </div>
                    
                    <div class="grupo-instintos">
                        <h3>Instintos <i class="fas fa-square" style="color:var(--assimilacao-red);"></i></h3>
                        <div class="grid-3col instintos-grid">
                            <div class="stat-box">
                                <label><a class="roll-instinto" data-instinto="influencia"><i class="fas fa-dice-d6"></i> Influência</a></label>
                                <input type="number" name="system.instintos.influencia" value="{{system.instintos.influencia}}" min="1" max="5">
                            </div>
                            <div class="stat-box">
                                <label><a class="roll-instinto" data-instinto="percepcao"><i class="fas fa-dice-d6"></i> Percepção</a></label>
                                <input type="number" name="system.instintos.percepcao" value="{{system.instintos.percepcao}}" min="1" max="5">
                            </div>
                            <div class="stat-box">
                                <label><a class="roll-instinto" data-instinto="potencia"><i class="fas fa-dice-d6"></i> Potência</a></label>
                                <input type="number" name="system.instintos.potencia" value="{{system.instintos.potencia}}" min="1" max="5">
                            </div>
                            <div class="stat-box">
                                <label><a class="roll-instinto" data-instinto="reacao"><i class="fas fa-dice-d6"></i> Reação</a></label>
                                <input type="number" name="system.instintos.reacao" value="{{system.instintos.reacao}}" min="1" max="5">
                            </div>
                            <div class="stat-box">
                                <label><a class="roll-instinto" data-instinto="resolucao"><i class="fas fa-dice-d6"></i> Resolução</a></label>
                                <input type="number" name="system.instintos.resolucao" value="{{system.instintos.resolucao}}" min="1" max="5">
                            </div>
                            <div class="stat-box">
                                <label><a class="roll-instinto" data-instinto="sagacidade"><i class="fas fa-dice-d6"></i> Sagacidade</a></label>
                                <input type="number" name="system.instintos.sagacidade" value="{{system.instintos.sagacidade}}" min="1" max="5">
                            </div>
                        </div>
                    </div>

                    <div class="grupo-conhecimentos">
                        <h3>Conhecimentos <i class="fas fa-diamond" style="color:grey;"></i></h3>
                        <div class="grid-3col">
                            {{#each system.conhecimentos as |val key|}}
                            <div class="stat-box outline-box" style="display:flex; flex-direction:column;">
                                <label><a class="roll-aptidao" data-aptidao="{{key}}" data-categoria="conhecimentos"><i class="fas fa-dice-d10"></i> {{key}}</a></label>
                                <select class="instinto-combinar" style="flex:1; width:100%; border:1px solid #ccc; font-size:10px;">
                                    <option value="">(Instinto)</option>
                                    <option value="influencia">Influência</option>
                                    <option value="percepcao">Percepção</option>
                                    <option value="potencia">Potência</option>
                                    <option value="reacao">Reação</option>
                                    <option value="resolucao">Resolução</option>
                                    <option value="sagacidade">Sagacidade</option>
                                </select>
                                <input type="number" name="system.conhecimentos.{{key}}" value="{{val}}" min="0" max="5" style="margin-top:2px;">
                            </div>
                            {{/each}}
                        </div>
                    </div>

                    <div class="grupo-praticas">
                        <h3>Práticas <i class="fas fa-diamond" style="color:grey;"></i></h3>
                        <div class="grid-3col">
                            {{#each system.praticas as |val key|}}
                            <div class="stat-box outline-box-red" style="display:flex; flex-direction:column;">
                                <label><a class="roll-aptidao" data-aptidao="{{key}}" data-categoria="praticas"><i class="fas fa-dice-d10"></i> {{key}}</a></label>
                                <select class="instinto-combinar" style="flex:1; width:100%; border:1px solid #ccc; font-size:10px;">
                                    <option value="">(Instinto)</option>
                                    <option value="influencia">Influência</option>
                                    <option value="percepcao">Percepção</option>
                                    <option value="potencia">Potência</option>
                                    <option value="reacao">Reação</option>
                                    <option value="resolucao">Resolução</option>
                                    <option value="sagacidade">Sagacidade</option>
                                </select>
                                <input type="number" name="system.praticas.{{key}}" value="{{val}}" min="0" max="5" style="margin-top:2px;">
                            </div>
                            {{/each}}
                        </div>
                    </div>
                </div>

                <!-- COLUNA DIREITA: SAÚDE E STATUS -->
                <div class="col-saude">
                    <h2 class="section-title">Saúde <i class="fas fa-tint"></i></h2>
                    <p class="saude-calc">MÁX = 1+Potência+Resolução (Atual: {{system.pontosHPporNivel}})</p>

                    <div class="saude-container">
                        {{#each saudeNiveis as |nvl index|}}
                        <div class="saude-nivel">
                            <div class="saude-label">
                                <span class="badge">{{nvl.num}}</span>
                                <strong>{{nvl.nome}}</strong>
                            </div>
                            <!-- Tooltip CSS visual instantaneo -->
                            <div class="saude-hover-caixa" style="display:none; position:absolute; z-index:100; background:#222; color:#fff; padding:10px; border-radius:5px; font-size:12px; width:220px; border:1px solid #a73c39; transform: translateY(-100%);">{{nvl.tooltip}}</div>
                            <div class="saude-dots" data-nivel="nivel{{nvl.num}}">
                                {{#each nvl.dots as |dot|}}
                                    <i class="fas fa-heart saude-ponto {{#if dot.gasto}}gasto{{else}}livre{{/if}}" data-index="{{dot.index}}" title="Dano recebido"></i>
                                {{/each}}
                                <input type="hidden" name="system.saude.nivel{{nvl.num}}" value="{{nvl.gasto}}">
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
            </div>

            <hr>
            <!-- CABO DE GUERRA BELOW SAUDE/APTIDOES -->
            <div style="padding: 20px; border-radius: 4px; margin-top: 20px;">
                <h3 style=" font-family: 'Times New Roman', serif; text-align: center; margin-top: 0px;">Cabo de Guerra</h3>
                <div style="display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 20px;">
                    <div style="width: 40px; height: 40px; border-radius: 50%; border: 3px solid rgb(167, 60, 57); display: flex; align-items: center; justify-content: center; color: rgb(167, 60, 57); font-weight: bold; font-size: 1.2rem;">{{system.determinacaoNivel}}</div>
                    <div style="flex: 1 1 0%; display: flex; justify-content: center; flex-wrap: wrap; gap: 2px;">
                        {{#each cgDetDots as |dot index|}}
                        <svg class="cg-dot" data-tipo="det" data-index="{{dot.index}}" data-opaco="{{dot.opaco}}" width="30" height="20" viewBox="0 0 40 24" style="cursor: pointer; opacity: {{#if dot.opaco}}1{{else}}0.3{{/if}}; transition: opacity 0.2s;">
                            <path d="M20 0L0 12L20 24L40 12Z" fill="#a73c39" stroke="#a73c39" stroke-width="1"/>
                        </svg>
                        {{/each}}
                    </div>
                    <div style="width: 2px; height: 30px; background: rgb(51, 51, 51);"></div>
                    <div style="flex: 1 1 0%; display: flex; justify-content: center; flex-wrap: wrap; gap: 2px;">
                        {{#each cgAssDots as |dot index|}}
                        <svg class="cg-dot" data-tipo="ass" data-index="{{dot.index}}" data-opaco="{{dot.opaco}}" width="30" height="20" viewBox="0 0 40 24" style="cursor: pointer; opacity: {{#if dot.opaco}}1{{else}}0.3{{/if}}; transition: opacity 0.2s;">
                            <path d="M20 0L0 12L20 24L40 12Z" fill="#3b4766" stroke="#3b4766" stroke-width="1"/>
                        </svg>
                        {{/each}}
                    </div>
                    <div style="width: 40px; height: 40px; border-radius: 50%; border: 3px solid rgb(59, 71, 102); display: flex; align-items: center; justify-content: center; color: rgb(59, 71, 102); font-weight: bold; font-size: 1.2rem;">
                        <span>{{system.assimilacaoNivel}}</span>
                    </div>
                </div>
                <div style=" padding: 10px; border-top: 1px dashed rgb(51, 51, 51);">
                    <div style="display: flex; justify-content: space-between; color: rgb(136, 136, 136); font-size: 0.8rem; margin-bottom: 5px;">
                        <span>DETERMINAÇÃO</span>
                        <span>ASSIMILAÇÃO</span>
                    </div>
                    <input type="range" name="system.determinacaoNivel" min="0" max="10" value="{{system.determinacaoNivel}}" data-dtype="Number" style="width: 100%; appearance: none; height: 6px; background: linear-gradient(90deg, rgb(167, 60, 57), rgb(59, 71, 102)); outline: none; border-radius: 3px; cursor: pointer;">
                </div>
            </div>
        </div>

        <!-- ABA: VERSO -->
        <div class="tab verso" data-group="primary" data-tab="verso">
            <div class="grid-2col content-grid">
                <div class="verso-left">
                    <div class="propositos">
                        <label>Propósitos Pessoais</label>
                        <textarea name="system.propositos.pessoal1" placeholder="Propósito Pessoal 1">{{system.propositos.pessoal1}}</textarea>
                        <textarea name="system.propositos.pessoal2" placeholder="Propósito Pessoal 2">{{system.propositos.pessoal2}}</textarea>
                        
                        <label>Propósitos Coletivos</label>
                        <textarea name="system.propositos.relacional1" placeholder="Propósito Coletivo 1">{{system.propositos.relacional1}}</textarea>
                    </div>
                    <h2 class="section-title mt">Características</h2>
                    <textarea name="system.caracteristicas" placeholder="Características de Personagem...">{{system.caracteristicas}}</textarea>
                    
                    <h2 class="section-title mt">Assimilações</h2>
                    <textarea name="system.mutacoes" placeholder="Mutações...">{{system.mutacoes}}</textarea>

                    <h2 class="section-title mt">Anotações</h2>
                    <textarea name="system.notas" class="notas-textarea" placeholder="Anotações do Personagem...">{{system.notas}}</textarea>
                </div>
                
                <div class="verso-right">
                    <h2 class="section-title">Espaços de Inventário</h2>
                    
                    <div class="inventory-section">
                        <h3>Equipados no Corpo <a class="item-create" data-loc="corpo" title="Adicionar no Corpo"><i class="fas fa-plus"></i></a></h3>
                        <ul class="item-list">
                            {{#each itemsCorpo as |item|}}
                            <li class="item" data-item-id="{{item._id}}">
                                <img class="item-img" src="{{item.img}}" title="{{item.name}}"/>
                                <span class="item-name">{{item.name}}</span>
                                <span class="item-peso">Peso: {{item.system.peso}}</span>
                                <div class="item-controls">
                                    <a class="item-control item-edit" title="Editar"><i class="fas fa-edit"></i></a>
                                    <a class="item-control item-delete" title="Deletar"><i class="fas fa-trash"></i></a>
                                </div>
                            </li>
                            {{/each}}
                        </ul>

                        <h3 class="mt">Mochila <a class="item-create" data-loc="mochila" title="Adicionar na Mochila"><i class="fas fa-plus"></i></a></h3>
                        <ul class="item-list">
                            {{#each itemsMochila as |item|}}
                            <li class="item" data-item-id="{{item._id}}">
                                <img class="item-img" src="{{item.img}}" title="{{item.name}}"/>
                                <span class="item-name">{{item.name}}</span>
                                <span class="item-peso">Peso: {{item.system.peso}}</span>
                                <div class="item-controls">
                                    <a class="item-control item-edit" title="Editar"><i class="fas fa-edit"></i></a>
                                    <a class="item-control item-delete" title="Deletar"><i class="fas fa-trash"></i></a>
                                </div>
                            </li>
                            {{/each}}
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        
    </section>
</form>
