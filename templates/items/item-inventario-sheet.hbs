<form class="{{cssClass}} flexcol" autocomplete="off">
    <header class="sheet-header">
        <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
        <div class="header-fields">
            <h1 class="charname"><input name="name" type="text" value="{{item.name}}" placeholder="Nome do Item"/></h1>
            <div class="grid-2col">
                <div class="form-group">
                    <label>Tipo</label>
                    <select name="system.tipo">
                        {{selectOptions tipoOptions selected=system.tipo}}
                    </select>
                </div>
                <div class="form-group">
                    <label>Localização</label>
                    <select name="system.localizacao">
                        {{selectOptions localizacaoOptions selected=system.localizacao}}
                    </select>
                </div>
            </div>
            <div class="grid-2col mt-5">
                <div class="form-group">
                    <label>Quantidade</label>
                    <input type="number" name="system.quantidade" value="{{system.quantidade}}" min="0">
                </div>
                <div class="form-group">
                    <label>Espaços / Peso</label>
                    <input type="number" name="system.peso" value="{{system.peso}}" min="0">
                </div>
            </div>
        </div>
    </header>

    <!-- NAVEGAÇÃO -->
    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-tab="descricao">Descrição e Regras</a>
    </nav>

    <!-- CONTEÚDO PRINCIPAL -->
    <section class="sheet-body" style="flex: 1; display: flex; flex-direction: column; overflow: hidden; padding: 5px;">
        <textarea name="system.descricao" class="descricao-textarea" style="flex: 1; width: 100%; min-height: 150px; padding: 10px; resize: none; border-radius: 4px;" placeholder="Descrição e Regras...">{{system.descricao}}</textarea>
    </section>
    
    <style>
    .assimilacao.sheet.item .sheet-header { display: flex; gap: 15px; margin-bottom: 20px;}
    .assimilacao.sheet.item .profile-img { width: 90px; height: 90px; object-fit: cover; border: 2px solid #333; }
    .assimilacao.sheet.item .header-fields { flex: 1; display:flex; flex-direction:column; justify-content:center;}
    .assimilacao.sheet.item .charname input { font-size: 24px; font-weight: bold; border-bottom: 2px solid #8E5A2D;}
    .mt-5 { margin-top: 5px; }
    </style>
</form>
